{
  "name": "@gautamroshan/paperclip-agent-identities",
  "version": "0.2.2",
  "packageManager": "pnpm@10.17.1",
  "type": "module",
  "private": false,
  "description": "Per-agent identity providers and contribution tools for Paperclip",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "pnpm-lock.yaml"
  ],
  "scripts": {
    "build": "node ./esbuild.config.mjs",
    "build:rollup": "rollup -c",
    "dev": "node ./esbuild.config.mjs --watch",
    "dev:ui": "paperclip-plugin-dev-server --root . --ui-dir dist/ui --port 4177",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "docs:dev": "vitepress dev openwiki",
    "docs:build": "vitepress build openwiki",
    "docs:preview": "vitepress preview openwiki"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "keywords": [
    "paperclip",
    "plugin",
    "connector"
  ],
  "author": "Roshan Gautam",
  "license": "MIT",
  "devDependencies": {
    "@paperclipai/plugin-sdk": "2026.707.0",
    "@paperclipai/shared": "2026.707.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "19",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "react": "19.2.7",
    "react-dom": "19",
    "react-test-renderer": "19",
    "rollup": "^4.38.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vitepress": "1.6.4",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
